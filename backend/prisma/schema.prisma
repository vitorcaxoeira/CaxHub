generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String?
  nome         String
  fotoUrl      String?
  roleId       Int
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now())

  /// "pendente" (convite ainda não aceito, sem senha) | "ativo"
  status          String    @default("ativo")
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?

  // Vínculo opcional com o registro de origem em Consultor (view USU_VBI00Cons do Senior),
  // usado só para sugerir nome/papel ao criar um convite — não é uma FK obrigatória.
  consultorCodemp Int?
  consultorCodusu Int?
  consultor       Consultor? @relation(fields: [consultorCodemp, consultorCodusu], references: [codemp, codusu])

  preferenciaFluxoCaixa  PreferenciaFluxoCaixa?
  movimentacoesAtividade AtividadeHistoricoMovimentacao[]
  comentariosAtividade   AtividadeComentario[]
  anexosAtividade        AtividadeAnexo[]
  notificacoes           Notificacao[]
  auditEventos           AuditEvento[]
}

// Limiar mínimo de caixa configurado por usuário na Curva de Caixa Projetada (Fluxo de Caixa).
model PreferenciaFluxoCaixa {
  userId         Int      @id
  limiarCaixaMin Decimal  @default(0) @db.Decimal(15, 2)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("preferencias_fluxo_caixa")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id    Int              @id @default(autoincrement())
  name  String           @unique
  roles RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// Registra cada execução do job de sincronização SOAP -> Postgres.
model SyncLog {
  id      Int      @id @default(autoincrement())
  jobName String
  query   String
  status  String
  message String?
  runAt   DateTime @default(now())
}

// Espelho local da tabela E070EMP do Senior ERP (empresas cadastradas).
model Empresa {
  codemp  Int      @id
  nomemp  String
  sigemp  String   @db.VarChar(30)
  filiais Filial[]

  @@map("empresa")
}

// Espelho local da tabela E070FIL do Senior ERP (filiais de cada empresa).
model Filial {
  codemp Int
  codfil Int
  nomfil String
  sigfil String

  empresa Empresa @relation(fields: [codemp], references: [codemp])

  @@id([codemp, codfil])
  @@map("filial")
}

// Espelho local da tabela E085CLI do Senior ERP (clientes cadastrados).
model Cliente {
  codcli Int    @id
  nomcli String
  apecli String
  sencli String
  tipcli String
  tipmer String
  tipemc Int
  codram String
  insest String
  cgccpf BigInt
  endcli String
  cplend String
  cepcli Int
  baicli String
  cidcli String
  sigufs String
  codpai String

  titulosReceber TituloReceber[]
  propostas      Proposta[]

  @@map("clientes")
}

// Espelho local da tabela E002TPT do Senior ERP (Tabelas - Tipos de Título).
model TipoTitulo {
  codtpt String  @id @db.VarChar(3)
  destpt String  @db.VarChar(40)
  abrtpt String  @db.VarChar(5)
  /// Domínio "LSomTit": D=Soma Duplicatas, O=Soma Outros Títulos, C=Soma Créditos/Pgto. Indevidos
  recsom String  @db.VarChar(1)
  /// Domínio "LSomTit": D=Soma Duplicatas, O=Soma Outros Títulos, C=Soma Créditos/Pgto. Indevidos
  pagsom String  @db.VarChar(1)
  /// Domínio "LAplGrp": A=Ambos, R=Contas a Receber, P=Contas a Pagar
  apltpt String? @db.VarChar(1)
  /// Domínio "LSitReg": A=Ativo, I=Inativo
  sittpt String? @db.VarChar(1)

  titulosReceber TituloReceber[]

  @@map("tipos_titulo")
}

// Espelho local da tabela E301TCR do Senior ERP (C. Receber - Títulos - Dados Gerais).
model TituloReceber {
  codemp Int
  codfil Int
  numtit String   @db.VarChar(15)
  codtpt String   @db.VarChar(3)
  codcli Int
  /// Domínio "LSitTit": AO=Aberto ao Órgão de Proteção ao Crédito, AN=Aberto Negociação, AA=Aberto Advogado, AB=Aberto Normal, AC=Aberto Cartório, AE=Aberto Encontro de Contas, AI=Aberto Impostos, AJ=Aberto Retorno Jurídico, AP=Aberto Protestado, AR=Aberto Representante, AS=Aberto Suspenso, AV=Aberto Gestão de Pessoas, AX=Aberto Externo, CA=Cancelado, CE=Aberto CE (Preparação Cobrança Escritural), CO=Aberto Cobrança, LQ=Liquidado Normal, LC=Liquidado Cartório, LI=Liquidado Impostos, LM=Liquidado Compensado, LO=Liquidado Cobrança, LP=Liquidado Protestado, LS=Liquidado Substituído, LV=Liquidado Gestão de Pessoas, LX=Liquidado Externo, PE=Aberto PE (Pagamento Eletrônico)
  sittit String   @db.VarChar(2)
  datemi DateTime @db.Date
  vctori DateTime @db.Date
  vctpro DateTime @db.Date
  vlrori Decimal  @db.Decimal(15, 2)
  vlrabe Decimal? @db.Decimal(15, 2)
  codpor String?  @db.VarChar(4)

  cliente    Cliente                  @relation(fields: [codcli], references: [codcli])
  tipoTitulo TipoTitulo               @relation(fields: [codtpt], references: [codtpt])
  portador   Portador?                @relation(fields: [codemp, codpor], references: [codemp, codpor])
  movimentos MovimentoTituloReceber[]

  @@id([codemp, codfil, numtit, codtpt])
  @@map("titulos_receber")
}

// Espelho local da tabela E301MCR do Senior ERP (C. Receber - Títulos - Movimentos).
model MovimentoTituloReceber {
  codemp Int
  codfil Int
  numtit String    @db.VarChar(15)
  codtpt String    @db.VarChar(3)
  seqmov Int
  codtns String    @db.VarChar(5)
  datmov DateTime  @db.Date
  datpgt DateTime? @db.Date
  codfpg Int?
  vlrmov Decimal   @db.Decimal(15, 2)
  vlrliq Decimal?  @db.Decimal(15, 2)
  vlrjrs Decimal?  @db.Decimal(15, 2)
  vlrmul Decimal?  @db.Decimal(15, 2)
  vlrdsc Decimal?  @db.Decimal(15, 2)
  diaatr Int?
  codpor String?   @db.VarChar(4)
  codcrt String?   @db.VarChar(2)
  codccu String?   @db.VarChar(9)
  numcco String?   @db.VarChar(14)

  tituloReceber TituloReceber @relation(fields: [codemp, codfil, numtit, codtpt], references: [codemp, codfil, numtit, codtpt])
  transacao     Transacao     @relation(fields: [codemp, codtns], references: [codemp, codtns])

  @@id([codemp, codfil, numtit, codtpt, seqmov])
  @@map("movimentos_receber")
}

// Espelho local da tabela E090REP do Senior ERP (Cadastros - Representantes).
model Representante {
  codrep Int     @id
  nomrep String  @db.VarChar(100)
  aperep String  @db.VarChar(50)
  /// Domínio "LJurFis": J=Pessoa Jurídica, F=Pessoa Física
  tiprep String  @db.VarChar(1)
  cgccpf BigInt?
  /// Domínio "LSitReg": A=Ativo, I=Inativo
  sitrep String  @db.VarChar(1)
  cidrep String? @db.VarChar(60)
  sigufs String? @db.VarChar(2)

  @@map("representantes")
}

// Espelho local da tabela E044CCU do Senior ERP (Cadastros - Centros de Custos).
model CentroCusto {
  codemp Int
  codccu String  @db.VarChar(9)
  desccu String  @db.VarChar(80)
  abrccu String  @db.VarChar(20)
  /// Domínio "LTipCtc": 1=Produtivo/Operacional Indireto, 2=Produtivo/Operacional Direto, 3=Administrativo, 4=Comercial, 5=Financeiro
  tipccu Int
  ccupai String? @db.VarChar(9)
  /// Domínio "LAnaSin": A=Analítico(a), S=Sintético(a)
  anasin String? @db.VarChar(1)

  @@id([codemp, codccu])
  @@map("centros_custo")
}

// Espelho local da tabela E600MCC do Senior ERP (Tesouraria - Movimento - Movimentações das Contas).
model MovimentoConta {
  codemp Int
  numcco String   @db.VarChar(14)
  datmov DateTime @db.Date
  seqmov Int
  codfil Int?
  vlrmov Decimal  @db.Decimal(15, 2)
  debcre String   @db.VarChar(1)
  hismov String?  @db.VarChar(100)
  /// Domínio "LSitReg": A=Ativo, I=Inativo
  sitmcc String?  @db.VarChar(1)
  filmcr Int?
  nummcr String?  @db.VarChar(15)
  tptmcr String?  @db.VarChar(3)
  seqmcr Int?
  codpor String?  @db.VarChar(4)

  @@id([codemp, numcco, datmov, seqmov])
  @@map("movimentos_conta")
}

// Espelho local da tabela E091PLF do Senior ERP (Tabelas - Plano Financeiro - Contas).
model NaturezaFinanceira {
  codemp Int
  ctafin Int
  descta String @db.VarChar(80)
  abrcta String @db.VarChar(20)
  /// Domínio "LGruCta": A=Ativo (Contábil - Devedora), P=Passivo (Contábil - Credora), D=Despesas (Contábil - Devedora), R=Receitas (Contábil - Credora), X=Ambas (Contábil - Desp./Rec.), M=Receitas Financeiras, N=Despesas Financeiras, U=Conta Auxiliar, L=Patrimônio Líquido, V=Custo de Venda, C=Custo de Produção, S=Custo de Ordem Dedutora, E=Custo de Ordem Credora, O=Outros, T=Contas de Compensação
  defgru String @db.VarChar(1)
  /// Domínio "LAnaSin": A=Analítico(a), S=Sintético(a)
  anasin String @db.VarChar(1)
  /// Domínio "LNatCtb": D=Devedora, C=Credora
  natfin String @db.VarChar(1)
  /// Domínio "LSitReg": A=Ativo, I=Inativo
  sitfin String @db.VarChar(1)

  @@id([codemp, ctafin])
  @@map("naturezas_financeiras")
}

// Espelho local da tabela E039POR do Senior ERP (Cadastros - Portadores).
model Portador {
  codemp Int
  codpor String  @db.VarChar(4)
  despor String  @db.VarChar(30)
  abrpor String  @db.VarChar(10)
  codban String? @db.VarChar(3)
  codage String? @db.VarChar(7)
  numcco String? @db.VarChar(14)

  titulosReceber TituloReceber[]

  @@id([codemp, codpor])
  @@map("portadores")
}

// Espelho local da tabela E031MOE do Senior ERP (Tabelas - Moedas).
model Moeda {
  codmoe String @id @db.VarChar(3)
  desmoe String @db.VarChar(30)
  sigmoe String @db.VarChar(5)
  /// Domínio "LTipMoe": V=Valor, D=Índice, P=Percentual, E=Especial, H=Hora
  tipmoe String @db.VarChar(1)

  @@map("moedas")
}

// Espelho local da tabela E001TNS do Senior ERP (Tabelas - Transações).
model Transacao {
  codemp Int
  codtns String  @db.VarChar(5)
  destns String  @db.VarChar(60)
  /// Domínio "LTipBai": PG=Pagamento, DV=Devolução, AB=Abatimento, CA=Cancelamento, CR=Baixa Crédito, CP=Compensação, LP=Lucros e Perdas, SU=Substituição, NA=NÃO É BAIXA
  rectpb String? @db.VarChar(2)

  movimentos MovimentoTituloReceber[]

  @@id([codemp, codtns])
  @@map("transacoes")
}

// Espelho local da tabela USU_TE077PRO do Senior ERP (Propostas de Consultoria/Upgrade).
model Proposta {
  codemp    Int
  codpro    Int
  codcli    Int
  qtdhor    Int?
  datpro    DateTime? @db.Date
  usuger    Int?
  /// Domínio "USU_ForAte": P=Presencial, R=Remoto
  forate    String?   @db.VarChar(1)
  /// Domínio "USU_SitPro": 1=Abertura, 2=Comercial, 3=Enviada p/ Cliente, 4=Aprovada, 5=Rejeitada, 6=Cancelada, 7=Em Execução, 8=Executada, 9=Levantamento Interno
  sitpro    Int?
  horpro    Int?
  /// Domínio "USU_TipPro": 1=Projeto Novo, 2=Mólulo Adicional, 3=Serviços, 4=Desenvolvimento, 5=Terceiros
  tippro    Int?
  dessol    String?   @db.VarChar(200)
  consol    String?   @db.VarChar(400)
  prarea    String?   @db.VarChar(100)
  datenv    DateTime? @db.Date
  datret    DateTime? @db.Date
  numprj    Int
  datval    DateTime? @db.Date
  codfpj    Int
  /// Domínio "USU_TipProd": 1=Gestão Empresarial | ERP, 2=Gestão de Pessoas | HCM, 3=Gestão de Acesso e Segurança, 4=Implantação, 9=Outros, 5=SoelX
  sispro    Int?
  despro    String?   @db.VarChar(100)
  numero    BigInt?
  /// Domínio "LSimNao": S=Sim, N=Não
  obrfas    String?   @db.VarChar(1)
  /// Domínio "USU_LProExecut": 0=Ambos, 1=Suporte, 2=Consultoria, 3=Dev. SoelX
  executor  Int?
  obssit    String?   @db.VarChar(200)
  /// Domínio "LSimNao": S=Sim, N=Não
  liqbru    String?   @db.VarChar(1)
  codccu    String?   @db.VarChar(9)
  ctafin    Int?
  /// Domínio "USU_ClaPro": 1=Projetos Grandes > 300H, 2=Projetos Médios 100h a 299H, 3=Projetos Pequenos 25H a 99H, 4=Projetos Rápidos até 24H
  clapro    Int?
  /// Domínio "USU_AreExu": 1=Consultoria ERP, 2=Consultoria HCM, 3=Suporte ERP, 4=Suporte HCM, 5=Fábrica Software
  areexe    Int?
  idcom     Int
  codrep    Int
  /// Domínio "USU_TRatForFat": 00=Mediante RAT, 01=Finalização, 02=Antecipado, 03=Sem Faturamento, 04=Misto (Parte Antecipada e com RAT), 05=Faturamento Via Contrato, 06=Antecipado Saldo Finalização
  forfat    Int?
  dscfpg    String?   @db.VarChar(200)
  hispro    String?   @db.VarChar(999)
  obspro    String?   @db.VarChar(999)
  preent    DateTime? @db.Date
  /// Domínio "USU_PriPro": 1=Alta, 2=Media, 3=Baixa
  pripro    Int?
  /// Domínio "USU_StaPro": 1=Novo, 2=Agendado, 3=Iniciada, 4=Em Homologação, 5=Parado, 6=Comercial
  stapro    Int?
  /// Domínio "USU_TipVen": 1=Venda Serviços Cliente Novo, 2=Venda Consultiva Serviços Base, 3=Venda Serviços Reativa Base Clientes, 4=Outros Tipos de Propostas
  tipven    Int?
  ordemcns  Int?
  /// Domínio "USU_SitMot": 1=Atividades Proposta dentro do previsto, 2=Atividades Proposta Estouradas, 3=Atividades Proposta Horas Consumidas sem Saldo, 4=Propostas ADM e Comercial, 5=Proposta de Levantamento Comercial, 6=Proposta Estourada Projeto Aberto
  sitmot    Int?
  /// Domínio "USU_LTipPrj": 01=Serviço, 02=Comercial, 03=Administrativo, 04=Levantamento
  tipprj    Int?
  /// Domínio "USU_LFrmPrj": 01=Fechado, 02=Aberto
  frmprj    Int?
  codlev2   Int?
  clifat    Int?
  /// Domínio "LSimNao": S=Sim, N=Não
  exipedcli String?   @db.VarChar(1)
  pedcli    String?   @db.VarChar(40)
  /// Domínio "USU_TRatForFat": 00=Mediante RAT, 01=Finalização, 02=Antecipado, 03=Sem Faturamento, 04=Misto (Parte Antecipada e com RAT), 05=Faturamento Via Contrato, 06=Antecipado Saldo Finalização
  forfatrdv Int?
  /// Domínio "USU_ModPro": 0=Serviço, 1=Levantamento, 2=DRM
  modpro    Int?
  /// Domínio "USU_TRatForFat": 00=Mediante RAT, 01=Finalização, 02=Antecipado, 03=Sem Faturamento, 04=Misto (Parte Antecipada e com RAT), 05=Faturamento Via Contrato, 06=Antecipado Saldo Finalização
  forfatlev Int?
  numped    Int
  idbpm     Int?
  /// Domínio "USU_LDepExe": 00=Diretoria, 01=Administrativo, 02=Comercial, 03=Suporte ERP, 04=Suporte HCM, 05=Suporte TI ERP, 06=Suporte TI HCM, 08=Consultoria ERP, 09=Consultoria HCM, 10=Desenvolvimento, 11=DHO, 12=Documentação, 13=Processo Interno
  depexe    Int?
  /// Domínio "LSimNao": S=Sim, N=Não
  fathrsdes String?   @db.VarChar(1)

  cliente      Cliente        @relation(fields: [codcli], references: [codcli])
  itens        PropostaItem[]
  auditEventos AuditEvento[]

  @@id([codemp, codpro])
  @@index([sitpro])
  @@index([datpro])
  @@index([codrep])
  @@index([datenv, datret])
  @@index([datval])
  @@map("propostas")
}

// Espelho local da tabela USU_TE077ITE do Senior ERP (Itens de Serviço da Proposta).
model PropostaItem {
  codemp Int
  codpro Int
  seqite Int
  numprj Int
  codser String   @db.VarChar(14)
  qtdhor Int?
  valhor Decimal? @db.Decimal(11, 2)
  despro String?  @db.VarChar(2000)
  entpro String?  @db.VarChar(2000)
  codfpj Int
  /// Domínio "USU_LFatSer": S=Faturamento Normal, N=Sem Faturamento, A=Faturamento Antecipado, C=Atividades Comercial, H=Atividade Suporte, I=Investimento
  fatser String?  @db.VarChar(1)
  /// Domínio "USU_SitMot": 1=Atividades Proposta dentro do previsto, 2=Atividades Proposta Estouradas, 3=Atividades Proposta Horas Consumidas sem Saldo, 4=Propostas ADM e Comercial, 5=Proposta de Levantamento Comercial, 6=Proposta Estourada Projeto Aberto
  sitmot Int?
  /// Domínio "USU_TRatForFat": 00=Mediante RAT, 01=Finalização, 02=Antecipado, 03=Sem Faturamento, 04=Misto (Parte Antecipada e com RAT), 05=Faturamento Via Contrato, 06=Antecipado Saldo Finalização
  forfat Int?
  /// Domínio "USU_LTipPrj": 01=Serviço, 02=Comercial, 03=Administrativo, 04=Levantamento
  tipprj Int?
  /// Domínio "USU_LFrmPrj": 01=Fechado, 02=Aberto
  frmprj Int?
  /// Domínio "USU_LSitPrz": 0=Não Iniciado, 1=Prazo Estourado, 2=Dentro do Prazo
  sitprz Int?
  atvpso BigInt?
  /// Domínio "USU_LDepExe": 00=Diretoria, 01=Administrativo, 02=Comercial, 03=Suporte ERP, 04=Suporte HCM, 05=Suporte TI ERP, 06=Suporte TI HCM, 08=Consultoria ERP, 09=Consultoria HCM, 10=Desenvolvimento, 11=DHO, 12=Documentação, 13=Processo Interno
  depexe Int?

  proposta Proposta @relation(fields: [codemp, codpro], references: [codemp, codpro])

  @@id([codemp, codpro, seqite])
  @@index([depexe])
  @@map("propostas_itens")
}

// Espelho local da view USU_VBI00Cons do Senior ERP (consultores/usuários internos
// vinculados a fornecedor — usada para resolver USU_UsuGer em nome real).
model Consultor {
  codemp    Int
  codusu    Int
  codfor    Int?
  nomfor    String? @db.VarChar(100)
  /// Domínio "LSitReg": A=Ativo, I=Inativo
  sitfor    String? @db.VarChar(1)
  nomcom    String? @db.VarChar(127)
  conhab    Int?
  /// Domínio "USU_TipUsuRat": 1=Adm. Pleno, 2=Comercial, 3=Consultor de Serviços,
  /// 4=Gerente de Serviços, 5=Consultor Suporte, 6=Gerente Suporte, 7=Gerente Comercial,
  /// 8=Gerente Dev. SoelX, 9=Desenvolvedor SoelX (0 = não classificado, fora do domínio oficial)
  tipusurat Int?
  depexe    Int?
  depexedes String? @db.VarChar(250)
  email     String? @db.VarChar(200)

  usuariosCaxHub User[]

  @@id([codemp, codusu])
  @@map("consultores")
}

// Espelho local da tabela E600CCO do Senior ERP (Tesouraria - Conta - Cadastro).
model ContaCorrente {
  codemp Int
  numcco String @db.VarChar(14)
  descco String @db.VarChar(30)
  abrcco String @db.VarChar(10)
  /// Domínio "LSitReg": A=Ativo, I=Inativo
  sitcco String @db.VarChar(1)

  @@id([codemp, numcco])
  @@map("contas_correntes")
}

// Espelho local da tabela USU_TDEPEXECFG do Senior ERP (Config. do departamento executor).
model DepartamentoGestor {
  /// Domínio "USU_LDepExe": 00=Diretoria, 01=Administrativo, 02=Comercial, 03=Suporte ERP, 04=Suporte HCM, 05=Suporte TI ERP, 06=Suporte TI HCM, 08=Consultoria ERP, 09=Consultoria HCM, 10=Desenvolvimento, 11=DHO, 12=Documentação, 13=Processo Interno
  depexe Int
  codemp Int
  usuges BigInt

  @@id([codemp, depexe])
  @@map("departamentos_gestores")
}

// Espelho local da tabela USU_TDEPEXETIM do Senior ERP (Time de consultores do Departamento).
model DepartamentoTime {
  /// Domínio "USU_LDepExe": 00=Diretoria, 01=Administrativo, 02=Comercial, 03=Suporte ERP, 04=Suporte HCM, 05=Suporte TI ERP, 06=Suporte TI HCM, 08=Consultoria ERP, 09=Consultoria HCM, 10=Desenvolvimento, 11=DHO, 12=Documentação, 13=Processo Interno
  depexe Int
  codemp Int
  codusu BigInt
  usuger BigInt?
  datger DateTime? @db.Date
  horger Int?
  /// Domínio "LSitReg": A=Ativo, I=Inativo
  sitreg String    @db.VarChar(1)

  @@id([codemp, depexe, codusu])
  @@map("departamento_time")
}

// Espelho local da tabela USU_TE077ATI do Senior ERP (Distribuição Atividades por
// Consultor). Diferente de toda tabela sincronizada até aqui: essa integração é de
// mão dupla — o CaxHub vai gerar registros novos aqui (ainda não construído) e enviá-los
// pro ERP depois, então a PK local é NOSSA (`id` autoincrement), e `seqati` (a PK real
// do Senior, `USU_SeqAti`) fica como campo separado, opcional/único — é o campo de
// chaveamento usado tanto pra não duplicar linha já sincronizada do ERP quanto,
// futuramente, pra saber qual registro atualizar quando enviarmos dados pra lá.
// `seqite=0` no Senior é usado como "sem item de proposta vinculado" — o job de sync
// ignora essas linhas (ver atividadeConsultorSync.ts).
model AtividadeConsultor {
  id     Int     @id @default(autoincrement())
  seqati BigInt? @unique

  codemp Int
  codpro Int
  seqite Int
  codfor Int
  qtdhor Int?
  /// Domínio "LSitReg": A=Ativo, I=Inativo
  sitreg String?      @db.VarChar(1)
  datger DateTime?    @db.Date
  horger Int?
  usuger Int?
  perlib Int?
  fasid  Int
  fase   FaseProposta @relation(fields: [fasid], references: [fasid])
  selsol String?      @db.VarChar(1)

  // Planejamento de datas — conceito só do CaxHub (sem equivalente no Senior),
  // definido manualmente pelo Líder Técnico/Consultor pra alimentar a Timeline
  // (Gantt simplificado). Diferente de `datval` (prazo da proposta, vem do ERP).
  dataPrevistaInicio DateTime? @db.Date
  dataPrevistaFim    DateTime? @db.Date

  // Status do quadro Kanban — conceito só do CaxHub, sem equivalente no Senior
  // (não confundir com `sitreg`, que é Ativo/Inativo do ERP). Nulo até o primeiro
  // sync/movimentação atribuir a coluna inicial.
  colunaId                Int?
  coluna                  QuadroColuna?                    @relation(fields: [colunaId], references: [id])
  historico               AtividadeHistoricoMovimentacao[]
  comentarios             AtividadeComentario[]
  checklistItens          AtividadeChecklistItem[]
  anexos                  AtividadeAnexo[]
  notificacoes            Notificacao[]
  sincronizacoesPendentes SincronizacaoPendente[]
  sessoesExecucao         AtividadeSessaoExecucao[]

  // Quando a proposta está em modo "estrutura" (ver PropostaModoAlocacao), a alocação
  // aponta pro nó-folha da EAP em vez de só pro item — fica nulo no modo "item" (o
  // comportamento de sempre, sem mudança). Ver EstruturaAtividade.
  estruturaAtividadeId Int?
  estruturaAtividade   EstruturaAtividade? @relation(fields: [estruturaAtividadeId], references: [id])

  @@index([codemp, codpro, seqite])
  @@index([sitreg])
  @@map("atividades_consultor")
}

// EAP (Estrutura Analítica de Projeto) opcional de um item de proposta — pastas
// agrupando atividades-folha, no estilo da aba "Cronograma Físico" do Senior desktop.
// Dado 100% CaxHub, pendurado num PropostaItem específico: as horas continuam
// contratadas por item no Senior (PropostaItem.qtdhor), a EAP só fatia o trabalho de UM
// item em pedaços mais finos — não substitui o item como unidade de negócio. Só existe
// pra propostas em modo "estrutura" (ver PropostaModoAlocacao).
model EstruturaAtividade {
  id       Int  @id @default(autoincrement())
  codemp   Int
  codpro   Int
  // Null só em tipo="pasta": é uma "pasta raiz" da proposta inteira (não pertence a
  // nenhum item específico), usada só pra agrupar itens de PropostaItem entre si — ver
  // PropostaItemPosicao. Toda pasta/atividade "normal" (ligada a um item) mantém seqite
  // preenchido, como sempre foi.
  seqite   Int?

  parentId Int?
  parent   EstruturaAtividade?  @relation("EstruturaFilhos", fields: [parentId], references: [id])
  filhos   EstruturaAtividade[] @relation("EstruturaFilhos")

  /// "pasta" (só agrupa, sem duração/data própria) | "atividade" (folha, aloca consultor)
  tipo  String @db.VarChar(10)
  nome  String @db.VarChar(200)
  ordem Int

  // Só preenchido em tipo="atividade":
  duracaoHoras        Int? // minutos, mesma convenção de AtividadeConsultor.qtdhor
  dataPrevistaInicio  DateTime? @db.Date
  dataPrevistaFim     DateTime? @db.Date
  // Referência informativa a outro nó da mesma árvore — sem motor de recálculo de
  // datas nem validação de ciclo nesta fase, é só texto/link pra leitura humana.
  predecessoraId      Int?
  percentualConcluido Int? // 0-100, definido manualmente (sem apontamento real de horas ainda)

  // Responsável/dono da atividade — conceito à parte dos N consultores alocados
  // (AtividadeConsultor.codfor); é só uma referência informativa de quem "é dono" da
  // atividade, não substitui a distribuição de horas por consultor.
  responsavelCodfor Int?

  // Status manual — só relevante em tipo="atividade" (pasta/item têm status sempre
  // derivado dos descendentes na resposta da API, nunca armazenado aqui). "bloqueada"
  // nunca é gravado neste campo — é sempre calculado em tempo de leitura, comparando
  // com o status efetivo da predecessora.
  status String? @db.VarChar(20) // "nao_iniciada" | "em_curso" | "concluida"

  observacao String? @db.VarChar(1000)

  criadoEm  DateTime @default(now())
  criadoPor Int? // codusu de quem criou

  alocacoes AtividadeConsultor[]
  itensPosicionados PropostaItemPosicao[]

  @@index([codemp, codpro, seqite])
  @@map("estrutura_atividades")
}

// Posição de um item de proposta dentro de uma pasta raiz (ver EstruturaAtividade.seqite
// null) — dado 100% CaxHub, nunca tocado pelo sync do Senior (PropostaItem é espelhado
// integralmente de lá, não dá pra pendurar isso nele). Ausência de linha aqui = item
// "solto" (comportamento de sempre, direto na raiz da árvore da proposta). parentId
// sempre aponta pra uma EstruturaAtividade com seqite null (pasta raiz) — nunca pra uma
// pasta comum, ligada a um item.
model PropostaItemPosicao {
  codemp Int
  codpro Int
  seqite Int

  parentId Int
  parent   EstruturaAtividade @relation(fields: [parentId], references: [id])

  @@id([codemp, codpro, seqite])
  @@map("proposta_item_posicao")
}

// Gate por proposta: decide se ela é alocada "por item" (fluxo direto, de sempre) ou
// via EstruturaAtividade — escolhido uma vez, na primeira vez que alguém abre a
// proposta na Alocação, e travado assim que existir a primeira alocação (ver
// backend/src/routes/alocacao.ts). Dado 100% CaxHub, sem equivalente no Senior.
model PropostaModoAlocacao {
  codemp Int
  codpro Int
  /// "item" | "estrutura"
  modo        String   @db.VarChar(10)
  definidoEm  DateTime @default(now())
  definidoPor Int? // codusu

  @@id([codemp, codpro])
  @@map("proposta_modo_alocacao")
}

// Fila (outbox) de mudanças feitas no CaxHub que precisam ser propagadas de volta pro
// Senior (ex: mover um card de coluna). Existe porque hoje a integração com o Senior só
// tem canal de LEITURA confirmado (SOAP "Consulta Genérica", só SELECT — ver
// backend/src/soap/client.ts); não há ainda um endpoint de escrita mapeado do lado do
// Senior. `enviarParaSenior()` (backend/src/sync/outboxSenior.ts) por enquanto é um stub
// que sempre falha, propositalmente — o objetivo desta fase é ter fila/reprocessamento/
// auditoria prontos pra plugar o envio real assim que esse canal for confirmado.
model SincronizacaoPendente {
  id           Int                @id @default(autoincrement())
  atividadeId  Int
  atividade    AtividadeConsultor @relation(fields: [atividadeId], references: [id])
  tipo         String             @db.VarChar(40)
  payload      Json
  // pendente | enviado | bloqueado (bloqueado = excedeu o número máximo de tentativas,
  // precisa de intervenção manual — ver reprocessar() em outboxSenior.ts)
  status       String             @default("pendente") @db.VarChar(20)
  tentativas   Int                @default(0)
  ultimoErro   String?
  criadoEm     DateTime           @default(now())
  processadoEm DateTime?

  @@map("sincronizacao_pendente")
}

// Colunas configuráveis do quadro Kanban do módulo de Gestão de Projetos — dado 100%
// do CaxHub. Por enquanto um quadro global (mesmas colunas pra todos os departamentos);
// campo `depexe` fica de fora de propósito, pra não migrar dado se isso virar por
// departamento no futuro (adicionaria a coluna nula = "todos os departamentos" nesse caso).
model QuadroColuna {
  id              Int     @id @default(autoincrement())
  nome            String  @db.VarChar(60)
  ordem           Int
  corBadge        String? @db.VarChar(30)
  ehFinal         Boolean @default(false)
  // Ao entrar nessa coluna, notifica automaticamente o(s) Líder(es) Técnico(s)
  // (gestor do departamento da atividade) — ver PATCH /atividades/:id/mover.
  notificarGestor Boolean @default(false)

  // Marca colunas de trabalho ativo (ex.: "Em Andamento") — entrar nelas abre uma
  // AtividadeSessaoExecucao, sair fecha. Colunas neutras (backlog, aguardando,
  // concluído) não contam tempo. Ver PATCH /atividades/:id/mover.
  contaComoExecucao Boolean @default(false)

  atividades        AtividadeConsultor[]
  historicoAnterior AtividadeHistoricoMovimentacao[] @relation("colunaAnterior")
  historicoNova     AtividadeHistoricoMovimentacao[] @relation("colunaNova")
  sessoesExecucao   AtividadeSessaoExecucao[]

  @@map("quadro_colunas")
}

// Sessão de trabalho numa atividade — 100% CaxHub, sem espelho no Senior. É a fonte da
// verdade de "quanto tempo foi realmente trabalhado" (uma atividade de muitas horas pode
// ser trabalhada em várias sessões ao longo de dias/semanas). Hoje só é criada/fechada
// automaticamente pela movimentação de coluna no Kanban (ver PATCH /atividades/:id/mover
// e QuadroColuna.contaComoExecucao); no futuro também por um Start/Stop manual — mesma
// estrutura, o campo `origem` já diferencia as duas fontes.
model AtividadeSessaoExecucao {
  id          Int                @id @default(autoincrement())
  atividadeId Int
  atividade   AtividadeConsultor @relation(fields: [atividadeId], references: [id])
  colunaId    Int
  coluna      QuadroColuna       @relation(fields: [colunaId], references: [id])

  inicio DateTime
  fim    DateTime? // null = sessão em andamento

  /// "movimentacao_kanban" (hoje) | "manual" (Start/Stop futuro)
  origem String @db.VarChar(20)

  // true quando o consultor já revisou a sessão e ela virou um RatItem de verdade —
  // a partir daí, "horas realizadas" passa a contar via RatItem, não mais via sessão
  // (ver GET /apontamentos/sessoes-pendentes), pra não somar a mesma hora duas vezes.
  confirmada Boolean  @default(false)
  ratItemId  Int?
  ratItem    RatItem? @relation(fields: [ratItemId], references: [id])

  criadoEm DateTime @default(now())

  @@map("atividade_sessoes_execucao")
}

// Cabeçalho de RAT (Registro de Atividade Técnica) — espelho parcial de USU_TE777RAT
// (só os campos usados hoje pelo CaxHub, não a tabela inteira). Mão dupla como
// AtividadeConsultor/seqati: PK local é `id`; a chave natural do Senior
// (codemp+numprj+codfpj+numrat) só existe depois que o documento é confirmado lá — fica
// nula enquanto for um rascunho criado no CaxHub (ver POST /apontamentos/confirmar).
// Sem campo `sitreg`: não há soft-delete nesta tabela no Senior, cancelamento é só
// sitrat=5 (Cancelado), refletido visualmente, sem filtrar a linha.
model Rat {
  id     Int @id @default(autoincrement())
  codemp Int
  codfor Int // consultor executor (sem FK formal, mesmo padrão de AtividadeConsultor.codfor)

  numprj Int?
  codfpj Int?
  numrat Int? // nulo até o Senior confirmar
  codpro Int?
  codcli Int?

  datemi  DateTime? @db.Date
  dataApr DateTime? @db.Date
  /// Domínio "USU_LSITRAT": 9=Digitado 8=Impresso 6=Aprovado 5=Cancelado 4=Faturado 2=Faturado Parcial 1=Fechado
  sitrat  Int?
  obsrat  String?   @db.VarChar(250)
  usufor  Int?
  depexe  Int?

  // true = criado pelo consultor no CaxHub (ainda sem numrat confirmado); false = veio do
  // Senior via ratSync (apontamento feito direto no desktop por outro consultor).
  origemCaxHub Boolean @default(false)

  itens RatItem[]

  @@unique([codemp, numprj, codfpj, numrat])
  @@map("rats")
}

// Linha de apontamento (IAT) — espelho parcial de USU_TE777IAT. PK local `id`; chave
// natural (codemp, numrat, seqrat) só existe após confirmação no Senior. Sem `qtdhpor`
// (quantidade de horas em decimal) de propósito — a duração vem de horini/horfim, que
// por sua vez vêm da AtividadeSessaoExecucao confirmada (sessão é a fonte da verdade do
// tempo trabalhado, RAT/IAT é só o formato de exportação pro Senior).
model RatItem {
  id     Int @id @default(autoincrement())
  ratId  Int
  rat    Rat @relation(fields: [ratId], references: [id])
  codemp Int

  numprj Int?
  numrat Int?
  seqrat Int?

  codser String?   @db.VarChar(14)
  datati DateTime? @db.Date
  // Minutos desde meia-noite (confirmado com amostra real do Senior: 480=08:00,
  // 720=12:00 etc.) — nunca HHMM. Pra formatar: Math.trunc(v/60) + ":" + v%60.
  horini Int?
  horfim Int?
  desati String?   @db.VarChar(1000)

  codpro Int?
  seqite Int?
  codfas Int?
  datreg DateTime? @db.Date

  // Vínculo central: AtividadeConsultor.seqati executado. Sem @relation formal (mesmo
  // espírito de codfor em Rat) — casamento por valor em código, não FK rígida, porque os
  // dois lados podem estar nulos em momentos diferentes do ciclo de vida.
  seqati BigInt?

  origemCaxHub Boolean @default(false)
  sessoes      AtividadeSessaoExecucao[]

  @@unique([codemp, numrat, seqrat])
  @@map("rat_itens")
}

// Histórico de movimentação de atividades entre colunas do Kanban — dado 100% do
// CaxHub, usado tanto como auditoria quanto de base pra futuras automações por
// mudança de status (fase posterior, não implementada ainda).
model AtividadeHistoricoMovimentacao {
  id               Int      @id @default(autoincrement())
  atividadeId      Int
  colunaAnteriorId Int?
  colunaNovaId     Int
  userId           Int?
  movidoEm         DateTime @default(now())

  atividade      AtividadeConsultor @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  colunaAnterior QuadroColuna?      @relation("colunaAnterior", fields: [colunaAnteriorId], references: [id])
  colunaNova     QuadroColuna       @relation("colunaNova", fields: [colunaNovaId], references: [id])
  // SetNull (não Cascade) de propósito: a movimentação é histórico/auditoria — se o
  // usuário for excluído depois, o registro de "quem moveu" fica em branco, mas a
  // movimentação em si continua existindo.
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("atividade_historico_movimentacao")
}

// Comentários de colaboração numa atividade — dado 100% do CaxHub.
model AtividadeComentario {
  id          Int      @id @default(autoincrement())
  atividadeId Int
  userId      Int?
  texto       String   @db.VarChar(2000)
  criadoEm    DateTime @default(now())

  atividade AtividadeConsultor @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  // SetNull: comentário é histórico de colaboração, continua existindo mesmo se o
  // autor for excluído depois (mesmo padrão do histórico de movimentação).
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("atividade_comentarios")
}

// Itens de checklist de uma atividade — dado 100% do CaxHub.
model AtividadeChecklistItem {
  id          Int       @id @default(autoincrement())
  atividadeId Int
  texto       String    @db.VarChar(300)
  concluido   Boolean   @default(false)
  ordem       Int       @default(0)
  criadoEm    DateTime  @default(now())
  concluidoEm DateTime?

  atividade AtividadeConsultor @relation(fields: [atividadeId], references: [id], onDelete: Cascade)

  @@map("atividade_checklist_itens")
}

// Anexos de uma atividade — arquivo guardado em disco local (volume Docker), só o
// metadado fica no Postgres. Ver backend/src/routes/atividades.ts pro upload/download.
model AtividadeAnexo {
  id             Int      @id @default(autoincrement())
  atividadeId    Int
  userId         Int?
  nomeArquivo    String   @db.VarChar(255)
  caminhoArquivo String   @db.VarChar(500)
  tamanhoBytes   Int
  mimeType       String   @db.VarChar(100)
  criadoEm       DateTime @default(now())

  atividade AtividadeConsultor @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  user      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("atividade_anexos")
}

// Notificações in-app do usuário — dado 100% do CaxHub. Geradas manualmente (ex.: em
// resposta a uma ação) ou por automação (ex.: mudança de status numa coluna marcada
// com `notificarGestor`, ver QuadroColuna).
model Notificacao {
  id          Int      @id @default(autoincrement())
  userId      Int
  tipo        String   @db.VarChar(40)
  mensagem    String   @db.VarChar(500)
  atividadeId Int?
  lida        Boolean  @default(false)
  criadoEm    DateTime @default(now())

  // Cascade aqui (diferente de comentário/histórico) porque uma notificação sem
  // destinatário não tem propósito nenhum — não é registro de auditoria.
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  atividade AtividadeConsultor? @relation(fields: [atividadeId], references: [id], onDelete: SetNull)

  @@map("notificacoes")
}

// Espelho local da tabela USU_TFASESPRO do Senior ERP (Fases de acompanhamento das propostas).
model FaseProposta {
  fasid  Int    @id
  fasdes String @db.VarChar(50)

  atividades AtividadeConsultor[]

  @@map("fases_proposta")
}

// Trilha de auditoria transversal do CaxHub — dado 100% CaxHub, append-only (a aplicação
// nunca faz UPDATE/DELETE aqui). Um evento por mudança individualmente relevante; eventos
// nascidos da mesma "ação" (ex.: uma linha de sync que alterou 3 campos monitorados)
// compartilham `correlationId`. Ver backend/src/audit/ para a lógica de captura.
//
// RETENÇÃO (Fase 4 — documentado, não implementado): a tabela cresce sem expurgo hoje.
// Estratégia proposta para quando o volume justificar (ex.: > alguns milhões de linhas
// ou impacto perceptível de performance nos índices):
//   1. Arquivar (não apagar) eventos com `ocorridoEm` older que 24 meses — mover pra uma
//      tabela fria (`audit_evento_arquivo`, schema idêntico, sem os índices de consulta
//      "quente") ou exportar em lote pra arquivo (CSV/Parquet) em storage externo antes
//      de remover da tabela principal. Nunca DELETE simples sem cópia — auditoria não
//      pode "desaparecer", só sair do caminho quente de consulta.
//   2. Job mensal (mesmo padrão de cron dos outros jobs de sync em backend/src/sync/),
//      rodando fora do horário de pico, movendo em lotes pequenos (evita lock longo
//      numa tabela grande).
//   3. `GET /auditoria` e `GET /auditoria/entidade/:tipo/:id` (backend/src/routes/
//      auditoria.ts) passariam a consultar as duas tabelas só se um filtro de período
//      pedir explicitamente dados mais antigos que 24 meses — o caminho comum (sem
//      filtro de período longo) nunca toca a tabela fria.
//   4. Ajustar o prazo de 24 meses é só mudar a constante do job — não é um valor fixo
//      no schema nem no código de consulta.
model AuditEvento {
  id         BigInt   @id @default(autoincrement())
  ocorridoEm DateTime @default(now()) @db.Timestamptz(6)

  // Nulo quando o evento não tem usuário interativo por trás (origem "job"/
  // "integracao_senior" — sync não tem request HTTP nem usuário logado). SetNull pelo
  // mesmo motivo de AtividadeHistoricoMovimentacao.userId: o evento é histórico e
  // sobrevive à exclusão do usuário.
  usuarioId Int?
  usuario   User? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  /// "tela" | "api" | "job" | "integracao_senior"
  origem String @db.VarChar(20)

  // Ligação opcional com a proposta (par igual à PK real de Proposta), usada pelo filtro
  // mais comum ("auditoria desta proposta"). Nullable porque nem todo evento futuro
  // (Fase 2+) será de uma proposta.
  codemp   Int?
  codpro   Int?
  proposta Proposta? @relation(fields: [codemp, codpro], references: [codemp, codpro])

  // Identidade genérica da entidade auditada, independente de ter FK pra Proposta.
  // entidadeId é string porque as PKs reais variam (compostas em Proposta/PropostaItem,
  // simples em AtividadeConsultor na Fase 2) — ver encoding em
  // backend/src/audit/identidadeEntidade.ts.
  entidadeTipo   String  @db.VarChar(40)
  entidadeId     String  @db.VarChar(60)
  entidadeRotulo String? @db.VarChar(200)

  eventoTipo String @db.VarChar(60)

  // { campo: { de, para } } — sempre a forma bruta dos valores antes/depois.
  alteracoes Json?
  // Dados adicionais não capturados por "antes/depois" (ex.: rótulos humanos de status).
  metadata Json?

  correlationId String @db.Uuid

  @@index([codemp, codpro, ocorridoEm(sort: Desc)], map: "idx_audit_evento_proposta")
  @@index([entidadeTipo, entidadeId, ocorridoEm(sort: Desc)], map: "idx_audit_evento_entidade")
  @@index([eventoTipo, ocorridoEm(sort: Desc)], map: "idx_audit_evento_tipo")
  @@map("audit_evento")
}
